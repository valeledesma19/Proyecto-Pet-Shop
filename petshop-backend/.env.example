# Copiar este archivo a ".env" y ajustar los valores antes de levantar docker-compose.
# El archivo ".env" NO debe subirse al repositorio (ya esta en .gitignore).

# --- Base de datos ---
DB_NAME=petshop_db
DB_USERNAME=postgres
DB_PASSWORD=1234
DB_PORT=5432

# --- Backend ---
SERVER_PORT=8080
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
LOG_LEVEL=INFO

# --- JWT ---
# Generar una clave larga y aleatoria en produccion, por ejemplo con:
#   openssl rand -base64 64
JWT_SECRET=cambiaEstaClaveSecretaPorUnaMuyLargaYSeguraEnProduccion123456789
JWT_EXPIRATION_MS=86400000
